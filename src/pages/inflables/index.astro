                alt={`Renta de inflable ${p.name} en CDMX — ${p.category.toLowerCase()}, ${p.dims}`}
                width="400"
                height="300"
                loading="lazy"
                decoding="async"
                class="ic__img"
              />
              <div class="ic__overlay" aria-hidden="true">
                <span class="ic__badge" data-cat={p.category}>{p.category}</span>
                <span class="ic__dims">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
                  {p.dims}
                </span>
              </div>
            </div>
            <div class="ic__body">
              <h3 class="ic__name">{p.name}</h3>
              <p class="ic__desc">{p.desc}</p>
              <a
                href={waUrl(`Hola, me interesa cotizar el inflable ${p.name} (${p.dims}) — ¿está disponible?`)}
                class="ic__cta"
                target="_blank"
                rel="noopener noreferrer"
              >
                <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d={WA_ICON}/>
                </svg>
                Cotizar por WhatsApp
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ④ FAQ ────────────────────────────────────────────────────────────────── -->
  <div id="faq">
    <FAQWithContact
      eyebrow="Resolvemos tus dudas"
      title="Preguntas frecuentes"
      titleAccent="sobre inflables en renta"
      desc="Todo lo que necesitas saber antes de reservar tu inflable en CDMX."
      body={[
