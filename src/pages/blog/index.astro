---
// src/pages/blog/index.astro — Índice del blog INFLAFI
// Ruta: /blog — 40 artículos agrupados por modelo de inflable
import { getCollection } from 'astro:content'
import PageLayout from '@layouts/PageLayout.astro'
import SectionHeading from '@components/SectionHeading.astro'
import CTABanner from '@components/CTABanner.astro'
import { TAXONOMY, CONTACT, waUrl, WA_MESSAGES } from '@config/site'

const posts = await getCollection('blog', ({ data }) => !data.draft)

// Orden de modelos = orden del catálogo
const MODEL_ORDER = [
  'Micro Baby', 'Dragones Rojos', 'Mini Jungla', 'Gusanitos',
  'Extrem', 'Barco Pirata', 'Princesas', 'Castillo Blanco',
]

// Etiqueta de tipo de artículo derivada del slug
function postTag(id: string): string {
  if (id.includes('guia-renta')) return 'Guía de renta'
  if (id.includes('seguridad')) return 'Seguridad'
  if (id.includes('-vs-') || id.includes('comparativa')) return 'Comparativa'
  return 'Ideas de fiesta'
}

const groups = MODEL_ORDER.map((model) => ({
  model,
  cat: TAXONOMY.categories.find(
    (c) => c.slug === posts.find((p) => p.data.model === model)?.data.category,
  ),
  posts: posts
    .filter((p) => p.data.model === model)
    .sort((a, b) => a.id.localeCompare(b.id)),
})).filter((g) => g.posts.length > 0)
---

<PageLayout
  title="Blog de Renta de Inflables CDMX — Guías, Comparativas y Tips | INFLAFI"
  description="Guías completas, comparativas y tips de seguridad para rentar inflables en CDMX: Micro Baby, Dragones Rojos, Mini Jungla, Gusanitos, Extrem, Barco Pirata, Princesas y Castillo Blanco."
  breadcrumbs={[{ label: 'Blog' }]}
>
  <section class="blog">
    <SectionHeading
      eyebrow="Blog INFLAFI"
      title="Guías y consejos para rentar inflables"
      titleAccent="en CDMX"
      desc="Todo lo que los papás con experiencia ya saben: guías de renta por modelo, comparativas honestas, protocolos de seguridad e ideas para que la fiesta salga perfecta."
    />

    {groups.map((g) => (
      <div class="blog__group">
        <div class="blog__group-head">
          <h2 class="blog__group-title">{g.model}</h2>
          {g.cat && <a class="blog__group-link" href={g.cat.href}>{g.cat.label} →</a>}
        </div>
        <div class="blog__grid">
          {g.posts.map((p) => (
            <a class="card" href={`/blog/${p.id}`}>
              <span class="card__tag">{postTag(p.id)}</span>
              <h3 class="card__title">{p.data.title}</h3>
              <p class="card__desc">{p.data.description}</p>
              <span class="card__cta">Leer artículo →</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </section>

  <CTABanner
    heading="¿No sabes qué inflable elegir?"
    desc="Cuéntanos la edad de los niños, el espacio disponible y la fecha — te recomendamos el modelo ideal con precio y disponibilidad en minutos."
    variant="primary"
    btns={[
      { label: 'Escribir por WhatsApp', href: waUrl(WA_MESSAGES.cotizar), icon: 'wa', primary: true, external: true },
      { label: `Llamar: ${CONTACT.phone}`, href: `tel:${CONTACT.phoneE164}`, icon: 'phone', primary: false },
    ]}
    badge={`${CONTACT.hours.display} · Respuesta garantizada`}
  />
</PageLayout>

<style>
  .blog {
    max-width: var(--container-max, 1200px);
    margin-inline: auto;
    padding: var(--sp-10, 3rem) var(--container-px, 1.25rem) var(--sp-12, 4rem);
  }
  .blog__group { margin-top: var(--sp-10, 2.5rem); }
  .blog__group-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: var(--sp-4, 1rem); flex-wrap: wrap;
    border-bottom: 2px solid var(--c-border, #e5e7eb);
    padding-bottom: var(--sp-3, .75rem);
    margin-bottom: var(--sp-5, 1.25rem);
  }
  .blog__group-title {
    font-size: var(--text-xl, 1.35rem); font-weight: 800;
    color: var(--c-ink, #111827); margin: 0;
  }
  .blog__group-link {
    font-size: var(--text-sm, .9rem); font-weight: 600;
    color: var(--c-primary); text-decoration: none;
  }
  .blog__group-link:hover { text-decoration: underline; }

  .blog__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--sp-5, 1.25rem);
  }
  .card {
    display: flex; flex-direction: column; gap: var(--sp-3, .75rem);
    padding: var(--sp-5, 1.25rem);
    background: var(--c-white, #fff);
    border: 1px solid var(--c-border, #e5e7eb);
    border-radius: var(--radius-lg, 12px);
    text-decoration: none;
    transition: box-shadow .18s ease, transform .18s ease, border-color .18s ease;
  }
  .card:hover {
    border-color: var(--c-primary);
    box-shadow: 0 8px 24px rgba(0, 0, 0, .08);
    transform: translateY(-2px);
  }
  .card__tag {
    align-self: flex-start;
    font-size: var(--text-xs, .78rem); font-weight: 700;
    text-transform: uppercase; letter-spacing: .05em;
    color: var(--c-primary);
    background: var(--c-primary-light, #ede9fe);
    padding: .2rem .6rem; border-radius: var(--radius-full, 999px);
  }
  .card__title {
    font-size: var(--text-base, 1.05rem); font-weight: 700; line-height: 1.35;
    color: var(--c-ink, #111827); margin: 0;
  }
  .card__desc {
    font-size: var(--text-sm, .9rem); line-height: 1.6;
    color: var(--c-muted, #6b7280); margin: 0;
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card__cta {
    margin-top: auto;
    font-size: var(--text-sm, .9rem); font-weight: 600;
    color: var(--c-primary);
  }
</style>
