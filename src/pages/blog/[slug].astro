---
// src/pages/blog/[slug].astro — Artículo individual del blog INFLAFI
// Ruta: /blog/<slug> — 40 artículos SEO (5 por modelo de inflable)
import { getCollection, render } from 'astro:content'
import PageLayout from '@layouts/PageLayout.astro'
import CTABanner from '@components/CTABanner.astro'
import { TAXONOMY, CONTACT, waUrl, WA_MESSAGES } from '@config/site'

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft)
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }))
}

const { post } = Astro.props
const { Content } = await render(post)

const cat = TAXONOMY.categories.find((c) => c.slug === post.data.category)
const fecha = post.data.pubDate.toLocaleDateString('es-MX', {
  year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC',
})
---

<PageLayout
  title={post.data.seoTitle ?? post.data.title}
  description={post.data.seoDescription ?? post.data.description}
  pageType="article"
  noindex={post.data.noindex}
  breadcrumbs={[
    { label: 'Blog', href: '/blog' },
    { label: post.data.model },
  ]}
>
  <article class="post">
    <header class="post__header">
      <div class="post__meta">
        <a class="post__chip" href="/blog">Blog INFLAFI</a>
        {cat && <a class="post__chip post__chip--cat" href={cat.href}>{post.data.model}</a>}
        <time datetime={post.data.pubDate.toISOString().slice(0, 10)}>{fecha}</time>
      </div>
      <h1 class="post__title">{post.data.title}</h1>
      <p class="post__byline">Publicado por <strong>INFLAFI</strong> · Renta de Inflables CDMX</p>
    </header>

    <div class="post__body prose">
      <Content />
    </div>
  </article>

  <CTABanner
    heading={`¿Listo para rentar el ${post.data.model}?`}
    desc="Escríbenos por WhatsApp con la fecha, la colonia y el número de niños — respondemos con precio y disponibilidad en minutos."
    variant="primary"
    btns={[
      { label: 'Escribir por WhatsApp', href: waUrl(WA_MESSAGES.cotizar), icon: 'wa', primary: true, external: true },
      { label: `Llamar: ${CONTACT.phone}`, href: `tel:${CONTACT.phoneE164}`, icon: 'phone', primary: false },
    ]}
    badge={`${CONTACT.hours.display} · Respuesta garantizada`}
  />
</PageLayout>

<style>
  .post {
    max-width: var(--container-prose, 720px);
    margin-inline: auto;
    padding: var(--sp-10, 3rem) var(--container-px, 1.25rem) var(--sp-12, 4rem);
  }
  .post__meta {
    display: flex; flex-wrap: wrap; align-items: center;
    gap: var(--sp-3, .75rem);
    font-size: var(--text-sm, .9rem); color: var(--c-muted, #6b7280);
    margin-bottom: var(--sp-4, 1rem);
  }
  .post__chip {
    display: inline-block;
    padding: .25rem .75rem;
    border-radius: var(--radius-full, 999px);
    background: var(--c-primary-light, #ede9fe);
    color: var(--c-primary-dark, var(--c-primary));
    font-weight: 600; font-size: var(--text-xs, .8125rem);
    text-decoration: none;
  }
  .post__chip--cat { background: var(--c-surface, #f3f4f6); color: var(--c-ink, #111827); }
  .post__title {
    font-size: var(--text-3xl, clamp(1.75rem, 3.5vw, 2.5rem));
    font-weight: 800; line-height: 1.2; letter-spacing: -.02em;
    color: var(--c-ink, #111827); margin: 0 0 var(--sp-3, .75rem);
  }
  .post__byline {
    color: var(--c-muted, #6b7280);
    font-size: var(--text-sm, .9rem);
    margin: 0 0 var(--sp-8, 2rem);
    padding-bottom: var(--sp-5, 1.25rem);
    border-bottom: 1px solid var(--c-border, #e5e7eb);
  }

  /* ── Prose (markdown renderizado) ── */
  .prose :global(h2) {
    font-size: var(--text-xl, 1.4rem); font-weight: 700; line-height: 1.3;
    color: var(--c-ink, #111827);
    margin: var(--sp-10, 2.5rem) 0 var(--sp-4, 1rem);
  }
  .prose :global(h3) {
    font-size: var(--text-lg, 1.125rem); font-weight: 700;
    color: var(--c-ink, #111827);
    margin: var(--sp-6, 1.5rem) 0 var(--sp-3, .75rem);
  }
  .prose :global(p) {
    font-size: var(--text-base, 1.0625rem); line-height: 1.75;
    color: var(--c-ink, #1f2937); margin: 0 0 var(--sp-4, 1rem);
  }
  .prose :global(a) { color: var(--c-primary); text-decoration: underline; text-underline-offset: 2px; }
  .prose :global(ul), .prose :global(ol) { padding-left: 1.4rem; margin: 0 0 var(--sp-4, 1rem); }
  .prose :global(li) { line-height: 1.7; margin-bottom: var(--sp-2, .5rem); }
  .prose :global(blockquote) {
    margin: var(--sp-6, 1.5rem) 0;
    padding: var(--sp-4, 1rem) var(--sp-5, 1.25rem);
    border-left: 4px solid var(--c-primary);
    background: var(--c-surface, #f9fafb);
    border-radius: var(--radius-md, 8px);
  }
  .prose :global(blockquote p) { margin: 0; color: var(--c-ink, #374151); }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--c-border, #e5e7eb); margin: var(--sp-8, 2rem) 0; }

  /* Tablas: scroll horizontal en móvil */
  .prose :global(table) {
    width: 100%; border-collapse: collapse;
    margin: var(--sp-6, 1.5rem) 0;
    font-size: var(--text-sm, .9rem);
    display: block; overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }
  .prose :global(th), .prose :global(td) {
    border: 1px solid var(--c-border, #e5e7eb);
    padding: .6rem .8rem; text-align: left; vertical-align: top;
    min-width: 8rem;
  }
  .prose :global(th) {
    background: var(--c-surface, #f3f4f6);
    font-weight: 700; color: var(--c-ink, #111827);
    white-space: nowrap;
  }
  .prose :global(tr:nth-child(even) td) { background: color-mix(in srgb, var(--c-surface, #f9fafb) 55%, transparent); }

  @media (max-width: 640px) {
    .post { padding-top: var(--sp-6, 1.5rem); }
    .post__title { font-size: var(--text-2xl, 1.5rem); }
  }
</style>
