<style>
  /* ── Layout helpers ─────────────────────────────────────────── */
  .section { padding: clamp(3.5rem, 7vw, 5.5rem) 0; }
  .container { max-width: var(--container-max, 1400px); margin-inline: auto; padding-inline: var(--container-px, 1.5rem); }
  .section--svcs { background: var(--c-surface); }
  .section--pkgs { background: #faf5ff; }

  /* ── Inflables a fondo ──────────────────────────────────────── */
  .section--afondo { background: #f3f4f6; }
  .afondo {
    display: grid;
    gap: 1.5rem;
  }

  /* ── Catálogo grid ──────────────────────────────────────────── */
  .section--catalogo { background: var(--c-surface, #f9fafb); }
  .catalogo-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.25rem;
  }

  /* Card */
  .inflable-card {
    background: #fff;
    border-radius: 18px;
    border: 1px solid rgba(0,0,0,.07);
    box-shadow: 0 2px 10px rgba(0,0,0,.07), 0 1px 3px rgba(0,0,0,.04);
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  /* Media */
  .inflable-card__media {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
    flex-shrink: 0;
  }
  .inflable-card__img {
    width: 100%; height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Overlay con gradient + badges */
  .inflable-card__overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: .75rem;
    background: linear-gradient(
      to bottom,
      rgba(0,0,0,.42) 0%,
      transparent 38%,
      transparent 55%,
      rgba(0,0,0,.62) 100%
    );
    pointer-events: none;
  }
  .inflable-badge {
    align-self: flex-start;
    padding: .25rem .65rem;
    border-radius: 999px;
    font-size: .625rem;
    font-weight: 700;
    letter-spacing: .07em;
    text-transform: uppercase;
    color: #fff;
    background: rgba(124,58,237,.88);
  }
  .inflable-badge[data-cat="Chico"]   { background: rgba(22,163,74,.88); }
  .inflable-badge[data-cat="Mediano"] { background: rgba(37,99,235,.88); }
  .inflable-badge[data-cat="Grande"]  { background: rgba(234,88,12,.88); }
  .inflable-badge[data-cat="Niñas"]   { background: rgba(219,39,119,.88); }
  .inflable-badge[data-cat="Bodas"]   { background: rgba(124,58,237,.88); }

  .inflable-dims-pill {
    align-self: flex-end;
    display: inline-flex;
    align-items: center;
    gap: .3rem;
    padding: .22rem .6rem;
    background: rgba(0,0,0,.52);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border-radius: 999px;
    font-size: .6875rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: .01em;
  }

  /* Body */
  .inflable-card__body {
    padding: 1.125rem 1.125rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: .625rem;
    flex: 1;
  }
  .inflable-card__name {
    font-size: 1.0625rem;
    font-weight: 700;
    color: var(--c-ink, #111827);
    margin: 0;
    line-height: 1.25;
  }
  .inflable-card__desc {
    font-size: .8125rem;
    color: var(--c-ink-2, #4b5563);
    line-height: 1.65;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .inflable-card__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .45rem;
    margin-top: auto;
    padding: .75rem 1rem;
    background: #25d366;
    color: #fff;
    font-size: .8125rem;
    font-weight: 700;
    border-radius: 10px;
    text-decoration: none;
  }
  .inflable-card__cta:hover {
    background: #1fba59;
  }

  /* ── Categorías grid ────────────────────────────────────────── */
  .cats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-6, 1.5rem);
  }

  /* ── Servicios grid ──────────────────────────────────────────── */
  .svcs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5, 1.25rem);
  }

  /* ── Paquetes ────────────────────────────────────────────────── */
  .pkgs-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: center;
  }
  .pkgs-text { display: flex; flex-direction: column; gap: var(--sp-5, 1.25rem); }
  .pkgs-perks {
    list-style: none; margin: 0; padding: 0;
    display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-3, .75rem) var(--sp-6, 1.5rem);
  }
  .pkgs-perks li {
    display: flex; align-items: flex-start; gap: var(--sp-2, .5rem);
    font-size: var(--text-sm, .875rem); color: var(--c-ink-2);
  }
  .pkgs-perks svg { flex-shrink: 0; color: var(--c-primary); margin-top: 2px; }
  .pkgs-cta {
    display: inline-flex; align-items: center; gap: var(--sp-2, .5rem); align-self: flex-start;
    padding: .875rem 1.75rem; background: var(--c-primary); color: #fff;
    font-weight: var(--weight-bold, 700); font-size: .9375rem; border-radius: var(--radius-md, 8px);
    text-decoration: none; box-shadow: 0 6px 16px rgba(var(--c-primary-rgb), .32);
    transition: background var(--transition), gap var(--transition), box-shadow var(--transition);
  }
  .pkgs-cta:hover { background: var(--c-primary-dark); gap: var(--sp-3, .75rem); box-shadow: 0 8px 20px rgba(var(--c-primary-rgb), .4); }
  .pkgs-cta:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 3px; }
  .pkgs-fig { margin: 0; }
  .pkgs-img {
    width: 100%; height: auto; object-fit: cover; aspect-ratio: 4/3;
    border-radius: var(--radius-2xl, 20px);
    box-shadow: 0 20px 50px rgba(0,0,0,.14), 0 3px 10px rgba(0,0,0,.06);
  }

  /* ── Reseñas ────────────────────────────────────────────────── */
  .reviews-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-5, 1.25rem);
  }
  .review-card {
    background: var(--c-white, #fff);
    border: 1px solid var(--c-border, #e5e7eb);
    border-radius: var(--radius-xl, 16px);
    padding: clamp(1.25rem, 2.5vw, 1.75rem);
    display: flex;
    flex-direction: column;
    gap: var(--sp-4, 1rem);
  }
  .review-card__stars {
    display: flex;
    gap: 2px;
    color: #f59e0b;
  }
  .review-card__text {
    margin: 0;
    flex: 1;
  }
  .review-card__text p {
    font-size: var(--text-sm, .9375rem);
    color: var(--c-ink-2, #374151);
