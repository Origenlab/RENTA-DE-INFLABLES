  image="/images/og/default.jpg"
  pageType="home"
  schemaData={{ faqs: FAQS_DATA }}
>

  <!-- ① HERO — 2 col: izquierda badge+H1+accent+subtitle+CTAs / derecha 2 párrafos empresa -->
