---
// src/pages/renta-de-inflables-para-boda.astro — L3 · Inflables para Boda / XV Años · INFLAFI
// Ruta: /renta-de-inflables-para-boda
// SEO objetivo: "inflable para boda CDMX" · "castillo blanco inflable XV años" · "brincolín elegante evento CDMX"
// F7.1: el contenido vive en src/content/categorias/renta-de-inflables-para-boda.md
// (colección `categorias`). Esta página conserva su esqueleto y su CSS temático.

import PageLayout     from '@layouts/PageLayout.astro'
import Hero           from '@components/Hero.astro'
import SectionHeading from '@components/SectionHeading.astro'
import CategoryCard   from '@components/CategoryCard.astro'
import CategoryDetail from '@components/CategoryDetail.astro'
import CTABanner      from '@components/CTABanner.astro'
import FAQWithContact from '@components/FAQWithContact.astro'
import SectionMenu    from '@components/SectionMenu.astro'

import { getEntry } from 'astro:content'
import { waUrl, WA_MESSAGES, CONTACT } from '@config/site'

const WA_ICON = 'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z'

const entry = await getEntry('categorias', 'renta-de-inflables-para-boda')
if (!entry) throw new Error('Falta src/content/categorias/renta-de-inflables-para-boda.md')
const d = entry.data
---

<PageLayout
  title={d.title}
  description={d.description}
  image={d.image}
  pageType="category"
  breadcrumbs={[
    { label: 'Inflables', href: '/inflables' },
    { label: d.breadcrumbLabel, href: `/${entry.id}` },
  ]}
>

  <!-- MIGAS DE PAN ─────────────────────────────────────────────────────────── -->
  <nav class="breadcrumbs" aria-label="Migas de pan">
    <div class="bc-inner">
      <ol class="bc-list">
        <li><a href="/" class="bc-link">Inicio</a></li>
        <li aria-hidden="true" class="bc-sep">›</li>
        <li><a href="/inflables" class="bc-link">Inflables</a></li>
        <li aria-hidden="true" class="bc-sep">›</li>
        <li><span class="bc-current" aria-current="page">{d.breadcrumbLabel}</span></li>
      </ol>
    </div>
  </nav>

  <!-- HERO ────────────────────────────────────────────────────────────────── -->
  <Hero
    badge={d.hero.badge}
    title={d.hero.title}
    accent={d.hero.accent}
    subtitle={d.hero.subtitle}
    descRight={d.hero.descRight}
    ctas={[
      { text: d.hero.ctaText, href: waUrl(d.waMessage), variant: 'primary', whatsapp: true },
      { text: 'Ver ficha técnica', href: '#especificaciones', variant: 'outline' },
    ]}
    ariaLabel={d.hero.ariaLabel}
  />

  <!-- MENÚ DE SECCIONES ───────────────────────────────────────────────────── -->
  <SectionMenu items={[
    ...d.menuItems,
    {
      label: d.menuCta.label,
      sub: d.menuCta.sub,
      href: waUrl(d.waMessage),
      icon: WA_ICON,
      cta: true,
    },
  ]} />

  <!-- ① EL CASTILLO BLANCO A FONDO ────────────────────────────────────────── -->
  <section class="section" aria-labelledby={d.introHeadingId}>
    <div class="container">
      <SectionHeading
        id={d.introHeadingId}
        eyebrow={d.intro.eyebrow}
        title={d.intro.title}
        titleAccent={d.intro.titleAccent}
        desc={d.intro.desc}
        layout="duo"
        body={d.intro.body}
      />

      <CategoryDetail
        id={d.detail.id}
        eyebrow={d.detail.eyebrow}
        category={d.detail.category}
        title={d.detail.title}
        body={d.detail.body}
        points={d.detail.points}
        cta={{
          label: d.detail.ctaLabel,
          href: waUrl(d.waMessage),
          external: true,
        }}
        gallery={d.detail.gallery}
        as="h2"
      />
    </div>
  </section>

  <!-- ② FICHA TÉCNICA ──────────────────────────────────────────────────────── -->
  <section id="especificaciones" class="section section--specs" aria-labelledby="specs-heading">
    <div class="container">
      <SectionHeading
        id="specs-heading"
        eyebrow={d.specsHeading.eyebrow}
        title={d.specsHeading.title}
        titleAccent={d.specsHeading.titleAccent}
        desc={d.specsHeading.desc}
        layout="duo"
        body={d.specsHeading.body}
      />

      <div class="fspecs-grid">
        {d.featureSpecs.map(spec => (
          <div class="fspec-card">
            <div class="fspec-card__visual" style={`background: ${spec.gradient}`}>
              <svg width="52" height="52" viewBox="0 0 24 24" fill="none"
                stroke="rgba(255,255,255,0.95)" stroke-linecap="round" stroke-linejoin="round"
                aria-hidden="true" set:html={spec.svgContent}
              />
              <span class="fspec-card__tag">{spec.tag}</span>
            </div>
            <div class="fspec-card__body">
              <p class="fspec-card__label">{spec.label}</p>
              <strong class="fspec-card__value">{spec.value}</strong>
              <p class="fspec-card__detail">{spec.detail}</p>
            </div>
          </div>
        ))}
      </div>

      <div class="specs-panel">
        <div class="specs-panel__img-col">
          <div class="specs-panel__img-wrap">
            <img
              src={d.panel.src}
              alt={d.panel.alt}
              width="600" height="450" loading="lazy" decoding="async"
              class="specs-panel__img"
            />
            <div class="specs-panel__img-overlay">
              <span class="spio__badge">{d.panel.badge}</span>
              <div class="spio__meta">
                <span class="spio__dims">{d.panel.dims}</span>
                <span class="spio__cat">{d.panel.cat}</span>
              </div>
            </div>
          </div>
          <p class="specs-panel__img-note">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
            {d.panel.note}
          </p>
        </div>

        <div class="specs-panel__data-col">
          <p class="specs-panel__col-title">{d.panel.colTitle}</p>
          <div class="sspecs-grid">
            {d.secondarySpecs.map(s => (
              <div class="sspec">
                <span class="sspec__icon" aria-hidden="true">
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none"
                    stroke="currentColor" stroke-width="2"
                    stroke-linecap="round" stroke-linejoin="round"
                    set:html={s.svgContent}
                  />
                </span>
                <div class="sspec__info">
                  <span class="sspec__label">{s.label}</span>
                  <strong class="sspec__value">{s.value}</strong>
                  <span class="sspec__note">{s.note}</span>
                </div>
              </div>
            ))}
          </div>
          <div class="specs-panel__cta">
            <a href={waUrl(d.waMessage)} class="specs-panel__cta-btn" target="_blank" rel="noopener noreferrer">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={WA_ICON}/></svg>
              {d.panel.ctaLabel}
            </a>
            <span class="specs-panel__cta-note">{d.panel.ctaNote}</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ③ PARA QUÉ EVENTOS ──────────────────────────────────────────────────── -->
  <section id="cuando" class="section" aria-labelledby="cuando-heading">
    <div class="container">
      <SectionHeading
        id="cuando-heading"
        eyebrow={d.cuandoHeading.eyebrow}
        title={d.cuandoHeading.title}
        titleAccent={d.cuandoHeading.titleAccent}
        layout="duo"
        body={d.cuandoHeading.body}
      />

      <div class="scenarios-grid">
        {d.scenarios.map(s => (
          <div class="scenario-card">
            <div class="scenario-card__header">
              <span class="scenario-card__icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="1.8"
                  stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={`<path d="${s.icon}"/>`} />
                </svg>
              </span>
              {s.tag && <span class="scenario-card__tag">{s.tag}</span>}
            </div>
            <h3 class="scenario-card__title">{s.title}</h3>
            <p class="scenario-card__desc">{s.desc}</p>
          </div>
        ))}
      </div>

      <div class="cuando-cta">
        <p class="cuando-cta__text">{d.cuandoCtaText}</p>
        <a href={waUrl(WA_MESSAGES.cotizar)} class="cuando-cta__btn" target="_blank" rel="noopener noreferrer">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d={WA_ICON}/></svg>
          Consultar por WhatsApp
        </a>
      </div>
    </div>
  </section>

  <!-- ④ OTRAS CATEGORÍAS ───────────────────────────────────────────────────── -->
  <section id="otras-categorias" class="section section--otras" aria-labelledby="otras-heading">
    <div class="container">
      <SectionHeading
        id="otras-heading"
        eyebrow={d.otrasHeading.eyebrow}
        title={d.otrasHeading.title}
        titleAccent={d.otrasHeading.titleAccent}
        desc={d.otrasHeading.desc}
        layout="duo"
        body={d.otrasHeading.body}
      />
      <div class="otras-grid">
        {d.otrasCats.map((cat, i) => (
          <CategoryCard
            label={cat.label}
            href={cat.href}
            image={cat.image}
            imageAlt={cat.imageAlt}
            badge={cat.badge}
            blurb={cat.blurb}
            ctaLabel={cat.ctaLabel}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- ⑤ FAQ ────────────────────────────────────────────────────────────────── -->
  <FAQWithContact
    eyebrow={d.faqHeading.eyebrow}
    title={d.faqHeading.title}
    titleAccent={d.faqHeading.titleAccent}
    desc={d.faqHeading.desc}
    body={d.faqHeading.body}
    faqs={d.faqs}
    showContact={true}
  />

  <!-- CTA BANNER ───────────────────────────────────────────────────────────── -->
  <CTABanner
    heading={d.banner.heading}
    desc={d.banner.desc}
    variant="primary"
    btns={[
      { label: 'Cotizar por WhatsApp', href: waUrl(d.waMessage), icon: 'wa', primary: true, external: true },
      { label: `Llamar: ${CONTACT.phone}`, href: `tel:${CONTACT.phoneE164}`, icon: 'phone', primary: false },
    ]}
    badge={d.banner.badge}
  />

</PageLayout>

<style>
  .container { max-width: var(--container-max, 1400px); margin-inline: auto; padding-inline: var(--container-px, 1.5rem); }

  /* ── Breadcrumbs ─────────────────────────────────────────────── */
  .breadcrumbs { background: var(--c-white, #fff); border-bottom: 1px solid var(--c-border, #e5e7eb); }
  .bc-inner { max-width: var(--container-max, 1400px); margin-inline: auto; padding-inline: var(--container-px, 1.5rem); padding-block: .625rem; }
  .bc-list { list-style: none; margin: 0; padding: 0; display: flex; align-items: center; gap: .375rem; flex-wrap: wrap; }
  .bc-link    { font-size: .8125rem; color: var(--c-primary, #7c3aed); text-decoration: none; }
  .bc-link:hover { text-decoration: underline; }
  .bc-sep     { font-size: .8125rem; color: var(--c-muted, #9ca3af); user-select: none; }
  .bc-current { font-size: .8125rem; color: var(--c-ink-2, #4b5563); font-weight: 500; }

  /* ── Sections ───────────────────────────────────────────────── */
  .section        { padding: clamp(3.5rem, 7vw, 5.5rem) 0; }
  .section--specs { background: var(--c-surface, #f9fafb); }
  .section--otras { background: var(--c-surface, #f9fafb); }

  /* ── Feature specs ──────────────────────────────────────────── */
  .fspecs-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-bottom: 1.5rem; }
  .fspec-card { display: flex; flex-direction: column; border-radius: 20px; overflow: hidden; border: 1px solid #e5e7eb; box-shadow: 0 4px 20px rgba(0,0,0,.08); background: #fff; }
  .fspec-card__visual { position: relative; height: 168px; display: flex; align-items: center; justify-content: center; }
  .fspec-card__tag { position: absolute; top: .875rem; right: .875rem; padding: .22rem .65rem; background: rgba(255,255,255,.22); backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,.3); border-radius: 999px; font-size: .625rem; font-weight: 700; text-transform: uppercase; letter-spacing: .07em; color: #fff; white-space: nowrap; }
  .fspec-card__body { padding: 1.375rem 1.375rem 1.5rem; display: flex; flex-direction: column; gap: .5rem; flex: 1; }
  .fspec-card__label { font-size: .6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #9ca3af; margin: 0; }
  .fspec-card__value { font-size: 1.75rem; font-weight: 900; color: #111827; line-height: 1.1; letter-spacing: -.02em; }
  .fspec-card__detail { font-size: .875rem; color: #4b5563; line-height: 1.7; margin: 0; }

  /* ── Specs panel ─────────────────────────────────────────────── */
  .specs-panel { display: grid; grid-template-columns: 1fr 1.5fr; gap: 2.5rem; align-items: start; background: #fff; border: 1px solid #e5e7eb; border-radius: 24px; padding: 2rem; box-shadow: 0 2px 16px rgba(0,0,0,.06); }
  .specs-panel__img-wrap { position: relative; border-radius: 14px; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,.12); }
  .specs-panel__img { width: 100%; height: auto; aspect-ratio: 4/3; object-fit: cover; display: block; }
  .specs-panel__img-overlay { position: absolute; bottom: 0; left: 0; right: 0; padding: 2rem 1rem .875rem; background: linear-gradient(to top, rgba(0,0,0,.72) 0%, transparent 100%); display: flex; align-items: flex-end; justify-content: space-between; gap: .5rem; }
  .spio__badge { font-size: 1rem; font-weight: 800; color: #fff; letter-spacing: -.01em; }
  .spio__meta { display: flex; flex-direction: column; align-items: flex-end; gap: .125rem; }
  .spio__dims { font-size: .75rem; font-weight: 700; color: rgba(255,255,255,.9); font-family: monospace; }
  .spio__cat  { font-size: .625rem; color: rgba(255,255,255,.65); text-transform: uppercase; letter-spacing: .06em; }
  .specs-panel__img-note { display: flex; align-items: center; gap: .375rem; margin-top: .75rem; font-size: .75rem; color: #9ca3af; margin-bottom: 0; }
  .specs-panel__img-note svg { flex-shrink: 0; }
  .specs-panel__col-title { font-size: .6875rem; font-weight: 700; text-transform: uppercase; letter-spacing: .08em; color: #9ca3af; margin: 0 0 1rem; padding-bottom: .75rem; border-bottom: 1px solid #f3f4f6; }
  .sspecs-grid { display: grid; grid-template-columns: 1fr 1fr; gap: .625rem; margin-bottom: 1.5rem; }
  .sspec { display: flex; align-items: flex-start; gap: .625rem; padding: .875rem; background: #f9fafb; border-radius: 12px; border: 1px solid #f3f4f6; }
  /* Iconos en dorado — branding premium de esta categoría */
  .sspec__icon { display: flex; align-items: center; justify-content: center; width: 1.875rem; height: 1.875rem; border-radius: 8px; background: #fef3c7; color: #92400e; flex-shrink: 0; margin-top: .0625rem; }
  .sspec__info { display: flex; flex-direction: column; gap: .125rem; min-width: 0; }
  .sspec__label { font-size: .625rem; color: #9ca3af; font-weight: 700; text-transform: uppercase; letter-spacing: .06em; }
  .sspec__value { font-size: .9375rem; font-weight: 800; color: #111827; line-height: 1.2; }
  .sspec__note  { font-size: .6875rem; color: #6b7280; line-height: 1.4; margin-top: .0625rem; }
  .specs-panel__cta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
  .specs-panel__cta-btn { display: inline-flex; align-items: center; gap: .45rem; padding: .875rem 1.375rem; background: #25d366; color: #fff; font-weight: 700; font-size: .9375rem; border-radius: 10px; text-decoration: none; box-shadow: 0 4px 14px rgba(37,211,102,.3); }
  .specs-panel__cta-btn:hover { background: #1fba59; }
  .specs-panel__cta-note { font-size: .8125rem; color: #9ca3af; }

  /* ── Scenarios ──────────────────────────────────────────────── */
  .scenarios-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; margin-bottom: 2.5rem; }
  .scenario-card { display: flex; flex-direction: column; gap: .75rem; padding: 1.5rem; background: #fff; border: 1px solid #e5e7eb; border-radius: 18px; box-shadow: 0 2px 8px rgba(0,0,0,.05); }
  .scenario-card__header { display: flex; align-items: center; justify-content: space-between; gap: .5rem; }
  /* Iconos y tags en dorado para branding premium */
  .scenario-card__icon { display: flex; align-items: center; justify-content: center; width: 2.5rem; height: 2.5rem; border-radius: 12px; background: #fef3c7; color: #92400e; flex-shrink: 0; }
  .scenario-card__tag { font-size: .625rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; padding: .2rem .55rem; background: #fef3c7; color: #78350f; border-radius: 999px; white-space: nowrap; }
  .scenario-card__title { font-size: 1.0625rem; font-weight: 700; color: #111827; line-height: 1.3; margin: 0; }
  .scenario-card__desc  { font-size: .875rem; color: #4b5563; line-height: 1.7; margin: 0; }

  /* ── Cuando CTA bar — fondo cálido/dorado para la categoría premium */
  .cuando-cta { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; padding: 1.5rem 2rem; background: #fffbeb; border: 1px solid #fde68a; border-radius: 16px; flex-wrap: wrap; }
  .cuando-cta__text { font-size: 1rem; color: #374151; margin: 0; line-height: 1.5; }
  .cuando-cta__btn { display: inline-flex; align-items: center; gap: .5rem; padding: .875rem 1.5rem; background: #25d366; color: #fff; font-weight: 700; font-size: .9375rem; border-radius: 10px; text-decoration: none; white-space: nowrap; flex-shrink: 0; box-shadow: 0 4px 14px rgba(37,211,102,.3); }
  .cuando-cta__btn:hover { background: #1fba59; }

  /* ── Otras grid ─────────────────────────────────────────────── */
  .otras-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; }

  /* ── Responsive ─────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .specs-panel { grid-template-columns: 1fr 1.2fr; gap: 1.5rem; }
  }
  @media (max-width: 900px) {
    .fspecs-grid    { grid-template-columns: 1fr 1fr; }
    .specs-panel    { grid-template-columns: 1fr; }
    .specs-panel__img-col { order: -1; }
    .scenarios-grid { grid-template-columns: repeat(2, 1fr); }
    .otras-grid     { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .fspecs-grid    { grid-template-columns: 1fr; }
    .sspecs-grid    { grid-template-columns: 1fr; }
    .scenarios-grid { grid-template-columns: 1fr; }
    .otras-grid     { grid-template-columns: 1fr; }
    .cuando-cta     { flex-direction: column; align-items: flex-start; }
    .cuando-cta__btn { width: 100%; justify-content: center; }
    .specs-panel    { padding: 1.25rem; border-radius: 16px; }
    .specs-panel__cta { flex-direction: column; align-items: stretch; }
    .specs-panel__cta-btn { justify-content: center; }
  }
</style>
