---
// ServiceCard.astro — Tarjeta de servicio extra (pantalla, pintacaritas, etc.). INFLAFI.
interface Props {
  label: string;
  href: string;
  image?: string;
  imageAlt?: string;
  desc?: string;
  icon?: string;
  ctaLabel?: string;
  index?: number;
}
const {
  label,
  href,
  image,
  imageAlt,
  desc,
  ctaLabel = "Ver servicio",
  index = 99,
} = Astro.props;
const eager = index < 3;
---

<article class="svc-card">
  {image && (
    <a class="svc-card__media-link" href={href} tabindex="-1" aria-hidden="true">
      <div class="svc-card__media">
        <img
          src={image}
          alt={imageAlt ?? label}
          width="480" height="320"
          loading={eager ? "eager" : "lazy"}
          decoding="async"
          class="svc-card__img"
        />
        <span class="svc-card__overlay" aria-hidden="true"></span>
      </div>
    </a>
  )}
  <div class="svc-card__body">
    <h3 class="svc-card__title">
      <a href={href}>{label}</a>
    </h3>
    {desc && <p class="svc-card__desc">{desc}</p>}
    <a class="svc-card__cta" href={href}>
      {ctaLabel}
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </a>
  </div>
</article>

<style>
  .svc-card {
    display: flex; flex-direction: column; height: 100%;
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }
  .svc-card__media-link { display: block; }
  .svc-card__media {
    position: relative; aspect-ratio: 3/2; overflow: hidden;
    background: var(--c-surface);
  }
  .svc-card__img { width: 100%; height: 100%; object-fit: cover; }
  .svc-card__overlay { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 60%, rgba(124,58,237,.12) 100%); }
  .svc-card__body { display: flex; flex-direction: column; flex-grow: 1; gap: var(--sp-3); padding: var(--sp-4) var(--sp-5) var(--sp-5); }
  .svc-card__title {
    margin: 0; font-family: var(--font-heading);
    font-size: var(--text-base); font-weight: var(--weight-bold);
    line-height: var(--leading-snug); color: var(--c-ink);
  }
  .svc-card__title a { color: inherit; text-decoration: none; }
  .svc-card__title a:hover { color: var(--c-primary); }
  .svc-card__desc {
    margin: 0; font-size: var(--text-sm); color: var(--c-ink-2);
    line-height: var(--leading-normal); flex-grow: 1;
  }
  .svc-card__cta {
    margin-top: auto;
    display: inline-flex; align-items: center; gap: var(--sp-2);
    align-self: flex-start;
    padding: .5em 1em;
    font-size: var(--text-xs); font-weight: var(--weight-semibold);
    color: var(--c-primary); text-decoration: none;
    background: rgba(var(--c-primary-rgb), .08);
    border: 1px solid rgba(var(--c-primary-rgb), .2);
    border-radius: var(--radius-md);
    transition: background var(--transition), color var(--transition);
  }
  .svc-card__cta:hover { background: var(--c-primary); color: #fff; border-color: var(--c-primary); }
  .svc-card__cta:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }
</style>
