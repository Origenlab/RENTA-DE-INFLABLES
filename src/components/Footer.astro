---
// Footer.astro — Pie de página profesional INFLAFI. DATA-DRIVEN via site.ts.
import { SITE, CONTACT, TAXONOMY, waUrl, telUrl, WA_MESSAGES } from '@config/site'

const year = new Date().getFullYear()

const INFLABLES_COL = TAXONOMY.categories.filter(c =>
  ['chicos','medianos','grandes','ninas','ninos','bodas'].includes(c.slug)
)
const SERVICIOS_COL = TAXONOMY.services ?? []
---

<footer class="site-footer" role="contentinfo">
  <div class="sf-top">
    <div class="sf-inner">
      <div class="sf-brand">
        <a href="/" class="sf-wordmark" aria-label={`${SITE.name} — Inicio`}>
          <span class="sf-wordmark__text">INFLAFI</span>
        </a>
        <p class="sf-tagline">{SITE.tagline ?? 'Renta de Inflables para Fiestas en CDMX'}</p>
        <div class="sf-contact-ctas">
          <a href={waUrl(WA_MESSAGES.cotizar)} class="sf-cta sf-cta--wa" target="_blank" rel="noopener noreferrer">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Cotizar por WhatsApp
          </a>
          <a href={telUrl()} class="sf-cta sf-cta--phone">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.93 3.42 2 2 0 0 1 3.9 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 14.92v2z"/></svg>
            {CONTACT.phone}
          </a>
        </div>
      </div>

      <nav class="sf-nav" aria-label="Links del sitio">
        <div class="sf-col">
          <h3 class="sf-col__heading">Inflables</h3>
          <ul class="sf-col__list">
            {INFLABLES_COL.map(cat => (
              <li><a href={cat.href}>{cat.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="sf-col">
          <h3 class="sf-col__heading">Servicios</h3>
          <ul class="sf-col__list">
            {SERVICIOS_COL.map(svc => (
              <li><a href={`/servicios/${svc.id}`}>{svc.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="sf-col">
          <h3 class="sf-col__heading">Empresa</h3>
          <ul class="sf-col__list">
            <li><a href="/paquetes-para-fiestas-infantiles">Paquetes de Fiesta</a></li>
            <li><a href="/contacto">Contacto</a></li>
            <li><a href="/aviso-de-privacidad">Aviso de Privacidad</a></li>
          </ul>
        </div>
        <div class="sf-col">
          <h3 class="sf-col__heading">Contacto</h3>
          <address class="sf-address">
            <p class="sf-address__line">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              {CONTACT.street}, {CONTACT.city}
            </p>
            <p class="sf-address__line">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15.5 14"/></svg>
              {CONTACT.schedule?.display ?? 'Lun–Dom · 8am – 8pm'}
            </p>
            <p class="sf-address__line">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              <a href={`mailto:${CONTACT.email}`}>{CONTACT.email}</a>
            </p>
          </address>
        </div>
      </nav>
    </div>
  </div>

  <div class="sf-bottom">
    <div class="sf-inner sf-bottom__inner">
      <p class="sf-copy">
        &copy; {year} {SITE.name}. Todos los derechos reservados.
        <span class="sf-copy__sep" aria-hidden="true">·</span>
        <a href={SITE.url}>{SITE.domain}</a>
      </p>
      <p class="sf-by">
        Sitio creado por <a href="https://origenlab.mx" target="_blank" rel="noopener noreferrer">OrigenLab</a>
      </p>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background: linear-gradient(185deg, #13002C 0%, #1A0038 55%, #0C0020 100%);
    color: rgba(255,255,255,.75);
    margin-top: auto;
    border-top: 2px solid transparent;
    background-clip: padding-box;
    position: relative;
  }
  .site-footer::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: linear-gradient(90deg, #7c3aed 0%, #a855f7 40%, #ec4899 100%);
  }

  .sf-inner { max-width: var(--container-max, 1400px); margin-inline: auto; padding-inline: var(--container-px, 1.5rem); }
  .sf-top { padding: 4rem 0 3.5rem; }
  .sf-top .sf-inner { display: grid; grid-template-columns: 320px 1fr; gap: clamp(3rem, 6vw, 5rem); }

  .sf-brand { display: flex; flex-direction: column; gap: 1.1rem; }
  .sf-wordmark { display: inline-flex; text-decoration: none; width: fit-content; }
  .sf-wordmark__text {
    font-family: var(--font-heading);
    font-weight: var(--weight-black, 900);
    font-size: 2rem;
    letter-spacing: .06em;
    text-transform: uppercase;
    background: linear-gradient(120deg, #fff 30%, rgba(168,120,255,.85) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
  }
  .sf-wordmark:hover .sf-wordmark__text {
    background: linear-gradient(120deg, #fff 0%, #c084fc 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }
  .sf-tagline { font-size: var(--text-sm, .875rem); color: rgba(255,255,255,.45); line-height: 1.65; margin: 0; max-width: 26ch; }
  .sf-contact-ctas { display: flex; flex-direction: column; gap: .6rem; margin-top: .5rem; }
  .sf-cta { display: inline-flex; align-items: center; gap: .5rem; padding: .6em 1em; border-radius: var(--radius-md, 6px); font-size: var(--text-sm, .875rem); font-weight: var(--weight-semibold, 600); text-decoration: none; transition: background .15s ease; width: fit-content; }
  .sf-cta--wa { background: #25D366; color: #fff; }
  .sf-cta--wa:hover { background: #1eb358; }
  .sf-cta--phone { background: rgba(255,255,255,.1); color: rgba(255,255,255,.85); border: 1px solid rgba(255,255,255,.15); }
  .sf-cta--phone:hover { background: rgba(255,255,255,.15); color: #fff; }

  .sf-nav { display: grid; grid-template-columns: repeat(4, 1fr); gap: 2rem; }
  .sf-col__heading { font-family: var(--font-heading); font-size: .7rem; font-weight: var(--weight-bold, 700); text-transform: uppercase; letter-spacing: .1em; color: rgba(255,255,255,.4); margin: 0 0 1rem; }
  .sf-col__list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: .45rem; }
  .sf-col__list a { font-size: var(--text-sm, .875rem); color: rgba(255,255,255,.68); text-decoration: none; transition: color .15s ease; }
  .sf-col__list a:hover { color: #fff; }

  .sf-address { font-style: normal; display: flex; flex-direction: column; gap: .55rem; }
  .sf-address__line { display: flex; align-items: flex-start; gap: .45rem; font-size: var(--text-sm, .875rem); color: rgba(255,255,255,.6); margin: 0; line-height: 1.5; }
  .sf-address__line svg { flex-shrink: 0; margin-top: 2px; }
  .sf-address__line a { color: rgba(255,255,255,.75); text-decoration: none; }
  .sf-address__line a:hover { color: #fff; }

  .sf-bottom { border-top: 1px solid rgba(255,255,255,.08); padding: 1.125rem 0; }
  .sf-bottom__inner { display: flex; align-items: center; justify-content: space-between; gap: 1rem; }
  .sf-copy { margin: 0; font-size: var(--text-xs, .75rem); color: rgba(255,255,255,.35); }
  .sf-copy a { color: rgba(255,255,255,.5); text-decoration: none; }
  .sf-copy a:hover { color: #fff; }
  .sf-copy__sep { margin-inline: .35em; opacity: .5; }
  .sf-by { margin: 0; font-size: var(--text-xs, .75rem); color: rgba(255,255,255,.3); }
  .sf-by a { color: rgba(255,255,255,.5); text-decoration: none; }
  .sf-by a:hover { color: #fff; }

  @media (max-width: 1100px) {
    .sf-top .sf-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .sf-brand { max-width: 380px; }
    .sf-nav { grid-template-columns: repeat(4, 1fr); gap: 1.5rem; }
  }
  @media (max-width: 800px) {
    .sf-nav { grid-template-columns: repeat(2, 1fr); gap: 2rem 1.5rem; }
  }
  @media (max-width: 480px) {
    .sf-nav { grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .sf-bottom__inner { flex-direction: column; gap: .4rem; text-align: center; }
    .sf-contact-ctas { flex-direction: row; flex-wrap: wrap; }
  }
</style>
