---
// FAQWithContact.astro — Acordeón FAQ + bloque de contacto. INFLAFI.
// REGLA DURA: header siempre via SectionHeading layout="duo" (patrón canónico).
// REGLA DURA: waUrl() — nunca wa.me/<número> hardcodeado.
import SectionHeading from '@components/SectionHeading.astro'
import { waUrl, telUrl, CONTACT, WA_MESSAGES } from '@config/site'

export type FaqItem = { question: string; answer: string }

interface Props {
  eyebrow?: string
  title?: string
  titleAccent?: string
  desc?: string
  body?: string[]
  faqs?: FaqItem[]
  showContact?: boolean
}

const {
  eyebrow = 'Resolvemos tus dudas',
  title = 'Preguntas',
  titleAccent = 'frecuentes',
  desc = 'Encuentra las respuestas a las preguntas más comunes sobre nuestra renta de inflables en CDMX.',
  body = [
    'Seleccionamos las dudas más frecuentes sobre disponibilidad, instalación, seguridad y tiempos de entrega para que llegues a tu evento con todo claro. Si algo no está aquí, te respondemos en segundos.',
    'Nuestro equipo está disponible por WhatsApp de lunes a domingo. Escríbenos con tu fecha, zona y tipo de evento — te cotizamos sin compromiso y confirmamos disponibilidad al instante.',
  ],
  faqs = [],
  showContact = true,
} = Astro.props

const DEFAULT_FAQS: FaqItem[] = [
  { question: '¿En qué zonas de CDMX realizan entregas?', answer: 'Cubrimos toda la Ciudad de México y parte de la zona metropolitana, incluyendo Naucalpan, Tlalnepantla y Ecatepec. La entrega y recogida siempre están incluidas en el precio.' },
  { question: '¿Cuánto tiempo incluye la renta?', answer: 'Nuestros paquetes estándar incluyen 4 a 6 horas de renta. Si necesitas más tiempo, podemos extender la renta con un costo adicional. Consúltanos por WhatsApp.' },
  { question: '¿Necesito contratar energía eléctrica adicional?', answer: 'Los inflables requieren corriente alterna (contactos de 110V). En la mayoría de los hogares la instalación eléctrica estándar es suficiente. Llevamos extensiones de 30 metros.' },
  { question: '¿Qué pasa si llueve el día del evento?', answer: 'En caso de lluvia fuerte te contactamos con anticipación para reprogramar sin costo. Los inflables no pueden usarse bajo lluvia intensa por seguridad.' },
  { question: '¿Los inflables son seguros para niños pequeños?', answer: 'Sí. Todos nuestros inflables están certificados y limpios. Para niños menores de 3 años recomendamos los modelos chicos con supervisión constante de adultos.' },
  { question: '¿Cuánto espacio necesito para instalar el inflable?', answer: 'Depende del modelo. Los más pequeños necesitan aprox. 3×3 m y los grandes hasta 6×6 m. Te enviamos las medidas exactas al confirmar tu reserva.' },
  { question: '¿Cuál es el proceso para reservar?', answer: 'Solo escríbenos por WhatsApp o llámanos para verificar disponibilidad en tu fecha y zona. Pedimos un anticipo del 30% para asegurar tu reserva. El resto se paga el día del evento.' },
  { question: '¿Tienen paquetes que incluyan más servicios?', answer: 'Sí, ofrecemos paquetes completos con inflable + mobiliario + pintacaritas + máquina de palomitas y más. Consulta nuestra página de paquetes o escríbenos para armar tu paquete personalizado.' },
]

const items = faqs.length > 0 ? faqs : DEFAULT_FAQS
---

<section class="faqc" aria-labelledby="faq-heading">
  <div class="faqc__inner">

    <!-- Encabezado canónico: SIEMPRE SectionHeading layout="duo" -->
    <SectionHeading
      id="faq-heading"
      layout="duo"
      eyebrow={eyebrow}
      title={title}
      titleAccent={titleAccent}
      desc={desc}
      body={body}
    />

    <div class="faqc__body">
      <!-- Col izquierda: acordeón FAQ -->
      <div class="faqc__accordion" role="list">
        {items.map((item, i) => (
          <div class="faqc-item" role="listitem">
            <h3 class="faqc-item__h3">
              <button class="faqc-item__trigger" type="button" aria-expanded="false" aria-controls={`faq-panel-${i}`} id={`faq-btn-${i}`}>
                <span class="faqc-item__q">{item.question}</span>
                <span class="faqc-item__icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg>
                </span>
              </button>
            </h3>
            <div class="faqc-item__panel" id={`faq-panel-${i}`} role="region" aria-labelledby={`faq-btn-${i}`} aria-hidden="true">
              <div class="faqc-item__panel-inner">
                <p class="faqc-item__a">{item.answer}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- Col derecha: tarjeta de contacto -->
      {showContact && (
        <aside class="faqc__contact" aria-label="¿Más dudas? Contáctanos">
          <p class="faqc__contact-eyebrow">¿No encontraste lo que buscas?</p>
          <h3 class="faqc__contact-heading">Contáctanos directamente</h3>
          <p class="faqc__contact-desc">Respondemos por WhatsApp en minutos. También puedes llamarnos.</p>
          <div class="faqc__contact-btns">
            <a href={waUrl(WA_MESSAGES.default)} class="faqc__contact-wa" target="_blank" rel="noopener noreferrer">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Escribir por WhatsApp
            </a>
            <a href={telUrl()} class="faqc__contact-phone">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.99 12 19.79 19.79 0 0 1 1.93 3.42 2 2 0 0 1 3.9 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 14.92v2z"/></svg>
              {CONTACT.phone}
            </a>
          </div>
          <p class="faqc__contact-schedule">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15.5 14"/></svg>
            {CONTACT.schedule?.display ?? 'Lunes a Domingo, 8am – 8pm'}
          </p>
        </aside>
      )}
    </div>
  </div>
</section>

<style>
  .faqc { padding: clamp(4rem, 7vw, 6rem) 0; background: var(--c-surface); }
  .faqc__inner { max-width: var(--container-max); margin-inline: auto; padding-inline: var(--container-px); }

  /* SectionHeading tiene sus propios estilos scoped — no redefinir aquí */

  /* ── Cuerpo: acordeón + contacto ── */
  .faqc__body { display: grid; grid-template-columns: 1fr 360px; gap: clamp(2.5rem, 4vw, 4rem); align-items: start; }
  .faqc__accordion { display: flex; flex-direction: column; gap: .625rem; }

  /* Items del acordeón */
  .faqc-item { border-radius: var(--radius-md, 8px); border: 1px solid var(--c-border); background: var(--c-white); overflow: hidden; }
  .faqc-item__h3 { margin: 0; }
  .faqc-item__trigger { width: 100%; display: flex; align-items: center; justify-content: space-between; gap: 1.25rem; padding: 1.125rem 1.375rem; text-align: left; font-size: 1.0625rem; font-weight: var(--weight-semibold, 600); color: var(--c-ink); background: none; border: none; cursor: pointer; transition: color .15s ease, background .15s ease; }
  .faqc-item__trigger:hover { background: rgba(var(--c-primary-rgb), .04); color: var(--c-primary); }
  .faqc-item__trigger[aria-expanded="true"] { color: var(--c-primary); border-bottom: 1px solid var(--c-border); }
  .faqc-item__icon { flex-shrink: 0; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; transition: transform .22s ease; }
  .faqc-item__trigger[aria-expanded="true"] .faqc-item__icon { transform: rotate(180deg); }
  .faqc-item__q { flex: 1; }
  .faqc-item__panel { overflow: hidden; max-height: 0; transition: max-height .32s ease; }
  .faqc-item__panel[aria-hidden="false"] { max-height: 600px; }
  .faqc-item__panel-inner { padding: 1rem 1.375rem 1.25rem; }
  .faqc-item__a { font-size: .9875rem; color: var(--c-ink-2); line-height: 1.7; margin: 0; }

  /* Tarjeta de contacto */
  .faqc__contact { background: var(--c-white); border: 1px solid var(--c-border); border-radius: var(--radius-lg, 10px); padding: 2rem; position: sticky; top: calc(var(--stack-height) + 1.5rem); display: flex; flex-direction: column; gap: 1rem; }
  .faqc__contact-eyebrow { margin: 0; font-size: var(--text-xs, .75rem); font-weight: var(--weight-bold, 700); text-transform: uppercase; letter-spacing: .07em; color: var(--c-muted); }
  .faqc__contact-heading { margin: 0; font-size: 1.175rem; font-weight: var(--weight-bold, 700); color: var(--c-ink); line-height: 1.3; }
  .faqc__contact-desc { margin: 0; font-size: var(--text-sm); color: var(--c-muted); line-height: 1.6; }
  .faqc__contact-btns { display: flex; flex-direction: column; gap: .5rem; }
  .faqc__contact-wa, .faqc__contact-phone { display: flex; align-items: center; gap: .5rem; padding: .75rem 1rem; border-radius: var(--radius-md, 8px); font-size: var(--text-sm); font-weight: var(--weight-semibold, 600); text-decoration: none; transition: background .15s ease; }
  .faqc__contact-wa { background: #25D366; color: #fff; }
  .faqc__contact-wa:hover { background: #1eb358; }
  .faqc__contact-phone { background: rgba(var(--c-primary-rgb), .08); color: var(--c-primary); border: 1px solid rgba(var(--c-primary-rgb), .2); }
  .faqc__contact-phone:hover { background: var(--c-primary); color: #fff; }
  .faqc__contact-schedule { margin: 0; display: flex; align-items: center; gap: .4rem; font-size: var(--text-xs); color: var(--c-muted); }

  @media (max-width: 900px) {
    .faqc__body { grid-template-columns: 1fr; }
    .faqc__contact { position: static; }
  }
  @media (prefers-reduced-motion: reduce) {
    .faqc-item__panel, .faqc-item__icon { transition: none; }
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faqc-item__trigger').forEach(btn => {
    const panel = document.getElementById(btn.getAttribute('aria-controls')!)
    if (!panel) return
    btn.addEventListener('click', () => {
      const isOpen = btn.getAttribute('aria-expanded') === 'true'
      document.querySelectorAll<HTMLButtonElement>('.faqc-item__trigger').forEach(other => {
        if (other === btn) return
        const otherPanel = document.getElementById(other.getAttribute('aria-controls')!)
        other.setAttribute('aria-expanded', 'false')
        if (otherPanel) otherPanel.setAttribute('aria-hidden', 'true')
      })
      btn.setAttribute('aria-expanded', isOpen ? 'false' : 'true')
      panel.setAttribute('aria-hidden', isOpen ? 'true' : 'false')
    })
  })
</script>
